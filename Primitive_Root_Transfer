def export_jsonl(data, path):
    with open(path, "w") as f:
        for entry in data:
            f.write(json.dumps(entry, indent=None) + "\n")
    print(f"[✓] Exported {len(data)} training examples → {path}")

def export_pretty(data, path):
    with open(path, "w") as f:
        json.dump(data, f, indent=2)
    print(f"[✓] Pretty-printed → {path}")

def print_stats(data):
    print("\n── Training Data Statistics ──────────────────────────────")
    task_types = {}
    total_reward = 0
    self_corrected = 0
    for ex in data:
        t = ex["task_type"]
        task_types[t] = task_types.get(t, 0) + 1
        total_reward += ex["reward_signal"].get("reward", 0)
        if ex["metadata"].get("self_corrected"):
            self_corrected += 1
    print(f"  Total examples    : {len(data)}")
    print(f"  Task type coverage: {len(task_types)}/7")
    print(f"  Self-corrected    : {self_corrected}/{len(data)}")
    print(f"  Avg reward        : {total_reward/len(data):.2f}")
    for t, c in task_types.items():
        print(f"    [{c}] {t}")
    print("──────────────────────────────────────────────────────────\n")

