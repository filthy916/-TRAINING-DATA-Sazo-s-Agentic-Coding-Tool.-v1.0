-    s3.upload_file(tmp_local_path, BUCKET, s3_key)
-    redis.set(f"ready:{s3_key}", "1")
+    s3.upload_file(tmp_local_path, BUCKET, s3_key)
+    # Verify the upload landed before signaling readiness
+    waiter = s3.get_waiter('object_exists')
+    waiter.wait(
+        Bucket=BUCKET,
+        Key=s3_key,
+        WaiterConfig={'Delay': 2, 'MaxAttempts': 10}
