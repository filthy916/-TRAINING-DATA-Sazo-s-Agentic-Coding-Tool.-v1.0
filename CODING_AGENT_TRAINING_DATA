    \"\"\"
    import threading, time, collections

    def decorator(func):
        lock = threading.Lock()
        timestamps = collections.deque()

        def wrapper(*args, **kwargs):
            now = time.monotonic()
            with lock:
                while timestamps and timestamps[0] <= now - period:
                    timestamps.popleft()
                if len(timestamps) >= calls:
                    raise RateLimitExceeded(
